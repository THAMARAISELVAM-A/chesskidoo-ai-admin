<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chesskidoo AI Admin</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 20px;
            background-color: #f4f4f4;
            transition: background-color 0.3s;
        }
        h1, h2, h3 {
            color: #333;
        }
        .dark-theme {
            background-color: #333;
            color: #f4f4f4;
        }
        .theme-toggle {
            margin: 20px 0;
        }
        button {
            padding: 10px 15px;
            cursor: pointer;
            border: none;
            border-radius: 5px;
            font-size: 16px;
        }
    </style>
</head>
<body aria-label="Main Content">
    <div class="theme-toggle">
        <button id="toggleTheme">Toggle Light/Dark Theme</button>
    </div>
    <h1>Welcome to Chesskidoo AI Admin</h1>
    <h2>Student List</h2>
    <ul>
        <li>Rahul Gupta</li>
        <li>Priya Sharma</li>
        <li>Aditi Mehta</li>
        <li>Virat Singh</li>
    </ul>
    <script>
        const toggleButton = document.getElementById('toggleTheme');
        toggleButton.onclick = function() {
            document.body.classList.toggle('dark-theme');
        };
    </script>
</body>
</html>