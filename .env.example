# Environment Variables Template
# Copy this file to .env and fill in your actual values

# MongoDB Connection String
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.mongodb.net/chesskidoo?retryWrites=true&w=majority

# JWT Secret for authentication (change in production!)
JWT_SECRET=chesskidoo-secret-2024

# Port for local development
PORT=5000

# GitHub Configuration (for backup functionality)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_OWNER=your_github_username
GITHUB_REPO=your_repo_name

# Razorpay Configuration (for payment processing)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret