function renderPayChart(){
  const paid=students.filter(s=>s.payment==='Paid').length;
  const due=students.filter(s=>s.payment==='Due').length;
  const overdue=students.filter(s=>s.payment==='Overdue').length;
  const ctx = document.getElementById('payChart').getContext('2d');
  new Chart(ctx, {
    type:'doughnut',
    data:{
      labels:['Paid','Due','Overdue'],
      datasets:[{data:[paid,due,overdue],backgroundColor:['rgba(76,175,125,0.7)','rgba(224,160,32,0.7)','rgba(224,85,85,0.7)'],borderColor:['#4caf7d','#e0a020','#e05555'],borderWidth:1}]
