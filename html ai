  document.getElementById('plan-student-label').textContent = studentName;
  document.getElementById('plan-output').innerHTML = `<div style="color:var(--ivory3);text-align:center;padding:40px"><div class="typing-indicator" style="justify-content:center"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div><div style="margin-top:12px;font-size:12px">Generating plan…</div></div>`;
  try {
    const res = await fetch('https://api.anthropic.com/v1/messages',{ // Note: Requires a backend proxy
      method:'POST',
      headers:{'Content-Type':'application/json', 'x-api-key': 'YOUR_API_KEY', 'anthropic-version': '2023-06-01'},
      body:JSON.stringify({
        model:'claude-3-5-sonnet-20240620', max_tokens:1000,
        messages:[{role:'user',content:`Create a detailed chess training plan for:
Student: ${student.name}
Level: ${student.level}
ELO: ${student.elo}
Coach: ${student.coach}
Focus: ${focus}
Duration: ${duration}
${context ? 'Additional context: ' + context : ''}

Include:
- Weekly breakdown with specific tasks
- Recommended resources (books, puzzles, games to study)
- Progress milestones
- Practice exercises
- Coach session topics

Be specific and actionable.`}]
