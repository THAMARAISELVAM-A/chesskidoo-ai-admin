async function analyzeGame(){
  const pgn = document.getElementById('pgn-input').value.trim();
  const studentName = document.getElementById('pgn-student').value;
  if(!pgn){ showToast('Please paste a PGN first'); return; }
  const btn = document.getElementById('analyze-btn');
  btn.textContent = 'Analyzing…'; btn.disabled = true;
  const student = students.find(s=>s.name===studentName);
  const ctx = student ? `Student: ${student.name}, Level: ${student.level}, ELO: ${student.elo}` : 'Unknown student';
  document.getElementById('analysis-output').innerHTML = `<div style="color:var(--ivory3);text-align:center;padding:40px">
    <div class="typing-indicator" style="justify-content:center"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div>
    <div style="margin-top:12px;font-size:12px">Analyzing game…</div></div>`;
  if(studentName) document.getElementById('analysis-student-name').textContent = studentName;
  try {
    const res = await fetch('https://api.anthropic.com/v1/messages',{ // Note: Requires a backend proxy
      method:'POST',
      headers:{'Content-Type':'application/json', 'x-api-key': 'YOUR_API_KEY', 'anthropic-version': '2023-06-01'},
      body:JSON.stringify({
        model:'claude-3-5-sonnet-20240620', max_tokens:1000,
        system: "You are a chess coach AI.",
        messages:[{role:'user',content:`Analyze this game PGN and provide structured feedback for a chess student.

${ctx}

PGN:
${pgn}

Provide:
1. GAME SUMMARY (2-3 sentences)
2. KEY MISTAKES (list 3-4 critical errors with move numbers)
3. BRILLIANT MOVES (list 2-3 strong moves)
4. OPENING ASSESSMENT
5. ENDGAME ASSESSMENT (if applicable)
6. TOP 3 RECOMMENDATIONS for improvement based on this game

Format with clear headings. Be specific with move numbers.`}]
      })
    });
    const data = await res.json();
    const analysis = data.content?.find(b=>b.type==='text')?.text || 'Analysis failed';
    document.getElementById('analysis-output').innerHTML = formatAnalysis(analysis);
  } catch(e){
    document.getElementById('analysis-output').innerHTML = `<div style="color:var(--danger)">Error connecting to AI. Please try again.</div>`;
  }
  btn.textContent = 'Analyze with AI'; btn.disabled = false;
}

function formatAnalysis(text){
  return text
    .replace(/\n\n/g,'</p><p style="margin-bottom:12px">')
    .replace(/\*\*(.*?)\*\*/g,'<strong style="color:var(--ivory)">$1</strong>')
    .replace(/^/,'<p style="margin-bottom:12px">')
    .replace(/$/,'</p>');
}

