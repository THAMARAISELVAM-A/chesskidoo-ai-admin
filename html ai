// ──────────────────────────────────────────
// AI CHAT
// ──────────────────────────────────────────
let chatHistory = [];

function buildAcademyContext(){
  const summary = students.map(s=>`${s.name}: ${s.level}, ELO ${s.elo}, coach ${s.coach}, payment ${s.payment}, ${s.sessions} sessions`).join('\n');
  return `You are the AI admin assistant for Knight's Edge Chess Academy — a premium chess academy in Tokyo, Japan. You help the admin manage students, create training plans, draft communications, and provide chess coaching insights.

Academy data:
STUDENTS (${students.length} total):
${summary}

UPCOMING SESSIONS: ${sessions.slice(0,5).map(s=>`${s.student} with ${s.coach} on ${s.date} at ${s.time} (${s.focus})`).join(', ')}

COACHES: GM Fischer (handles Elite/Advanced), Sensei Nakamura (handles Intermediate/Advanced), Coach Patel (handles Beginner/Intermediate)

Be concise, professional, and actionable. Format responses clearly.`;
}

async function sendChat(){
  const input = document.getElementById('chat-input');
  const msg = input.value.trim();
  if(!msg) return;
  input.value = '';
  addMsg('user', msg);
  chatHistory.push({role:'user',content:msg});
  const typingId = addTyping();
  try {
    const res = await fetch('https://api.anthropic.com/v1/messages',{ // Note: Requires a backend proxy to avoid CORS
      method:'POST',
      headers:{'Content-Type':'application/json', 'x-api-key': 'YOUR_API_KEY', 'anthropic-version': '2023-06-01'},
      body:JSON.stringify({
        model:'claude-3-5-sonnet-20240620',
        max_tokens:1000,
        system: buildAcademyContext(),
        messages: chatHistory
      })
    });
    const data = await res.json();
    removeTyping(typingId);
    const reply = data.content?.find(b=>b.type==='text')?.text || 'Sorry, I could not process that.';
    chatHistory.push({role:'assistant',content:reply});
    addMsg('ai', reply);
  } catch(e){
    removeTyping(typingId);
    addMsg('ai','Connection error. Please try again.');
  }
}

function addMsg(role, text){
  const container = document.getElementById('chat-messages');
  const time = new Date().toLocaleTimeString('en',{hour:'2-digit',minute:'2-digit'});
  const el = document.createElement('div');
  el.className = `msg ${role}`;
  el.innerHTML = `
    <div class="msg-avatar ${role==='ai'?'msg-ai-av':'msg-user-av'}">${role==='ai'?'♚':'A'}</div>
    <div>
      <div class="msg-bubble">${text.replace(/\n/g,'<br/>')}</div>
      <div class="msg-time">${time}</div>
    </div>`;
  container.appendChild(el);
  container.scrollTop = container.scrollHeight;
}

function addTyping(){
  const container = document.getElementById('chat-messages');
  const id = 'typing-'+Date.now();
  const el = document.createElement('div');
  el.className = 'msg ai'; el.id = id;
  el.innerHTML = `<div class="msg-avatar msg-ai-av">♚</div><div><div class="msg-bubble"><div class="typing-indicator"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div></div></div>`;
  container.appendChild(el);
  container.scrollTop = container.scrollHeight;
  return id;
}

function removeTyping(id){ document.getElementById(id)?.remove(); }

function quickPrompt(text){
  document.getElementById('chat-input').value = text;
  sendChat();
}

