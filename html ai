Chart.defaults.color = '#7a7468';
Chart.defaults.borderColor = 'rgba(201,168,76,0.1)';
Chart.defaults.font.family = "'DM Sans', sans-serif";

function initDashboardCharts(){
  const top8 = [...students].sort((a,b)=>b.elo-a.elo).slice(0,8);
  const ctx1 = document.getElementById('eloChart').getContext('2d');
  new Chart(ctx1, {
    type:'bar',
    data:{
      labels: top8.map(s=>s.name.split(' ')[0]),
      datasets:[{
        label:'ELO',
        data: top8.map(s=>s.elo),
        backgroundColor:'rgba(201,168,76,0.3)',
        borderColor:'rgba(201,168,76,0.8)',
        borderWidth:1,
        borderRadius:4,
      }]
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{legend:{display:false}},
      scales:{
        y:{min:800,ticks:{color:'#7a7468'},grid:{color:'rgba(201,168,76,0.07)'}},
        x:{ticks:{color:'#c8c0a8'},grid:{display:false}}
      }
    }
  });

  const levelCounts = {Beginner:0,Intermediate:0,Advanced:0,Elite:0};
  students.forEach(s=>levelCounts[s.level]++);
  const ctx2 = document.getElementById('levelChart').getContext('2d');
  new Chart(ctx2, {
    type:'doughnut',
    data:{
      labels:['Beginner','Intermediate','Advanced','Elite'],
      datasets:[{
        data:Object.values(levelCounts),
        backgroundColor:['rgba(76,175,125,0.7)','rgba(224,160,32,0.7)','rgba(74,158,255,0.7)','rgba(201,168,76,0.7)'],
        borderColor:['#4caf7d','#e0a020','#4a9eff','#c9a84c'],
        borderWidth:1,
      }]
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{legend:{position:'right',labels:{color:'#c8c0a8',padding:12,font:{size:12}}}}
    }
  });
}

function renderRevenueChart(){
  const ctx = document.getElementById('revenueChart').getContext('2d');
  new Chart(ctx, {
    type:'line',
    data:{
      labels:['Oct','Nov','Dec','Jan','Feb','Mar'],
      datasets:[{
        label:'Revenue (¥)',
