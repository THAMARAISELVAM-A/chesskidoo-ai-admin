<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Knight's Edge Academy — AI Admin</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root {
  --bg: #0e0e10;
  --bg2: #16161a;
  --bg3: #1e1e24;
  --bg4: #26262e;
  --gold: #c9a84c;
  --gold2: #e8cc7a;
  --gold3: #8a6c2a;
  --ivory: #f0ead6;
  --ivory2: #c8c0a8;
  --ivory3: #7a7468;
  --accent: #4a9eff;
  --success: #4caf7d;
  --warning: #e0a020;
  --danger: #e05555;
  --border: rgba(201,168,76,0.15);
  --border2: rgba(201,168,76,0.08);
  --radius: 10px;
  --radius-lg: 14px;
  --font-head: 'Playfair Display', Georgia, serif;
  --font-body: 'DM Sans', sans-serif;
  --font-mono: 'DM Mono', monospace;
  --sidebar-w: 220px;
  --transition: 0.18s ease;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { font-size: 14px; }
body { background: var(--bg); color: var(--ivory); font-family: var(--font-body); min-height: 100vh; display: flex; overflow-x: hidden; }

/* Sidebar */
.sidebar {
  width: var(--sidebar-w); min-height: 100vh; background: var(--bg2);
  border-right: 1px solid var(--border); display: flex; flex-direction: column;
  position: fixed; top: 0; left: 0; z-index: 100;
}
.sidebar-logo {
  padding: 22px 18px 16px; border-bottom: 1px solid var(--border2);
  display: flex; align-items: center; gap: 10px;
}
.logo-mark {
  width: 34px; height: 34px; background: var(--gold); border-radius: 8px;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  font-size: 18px;
}
.logo-name { font-family: var(--font-head); font-size: 13px; color: var(--gold2); line-height: 1.3; }
.logo-sub { font-size: 10px; color: var(--ivory3); font-weight: 300; letter-spacing: 0.04em; }

.sidebar-section { padding: 14px 10px 4px; font-size: 9px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--ivory3); }
.nav-item {
  display: flex; align-items: center; gap: 10px; padding: 9px 12px; margin: 2px 8px;
  border-radius: var(--radius); cursor: pointer; transition: background var(--transition);
  font-size: 13px; color: var(--ivory2); font-weight: 400;
}
.nav-item:hover { background: var(--bg3); color: var(--ivory); }
.nav-item.active { background: rgba(201,168,76,0.12); color: var(--gold2); }
.nav-item svg { width: 15px; height: 15px; flex-shrink: 0; opacity: 0.8; }
.nav-item.active svg { opacity: 1; }
.nav-badge {
  margin-left: auto; background: var(--danger); color: #fff;
  font-size: 10px; padding: 1px 6px; border-radius: 99px; font-weight: 500;
}

.sidebar-footer {
  margin-top: auto; padding: 14px 12px; border-top: 1px solid var(--border2);
  font-size: 11px; color: var(--ivory3);
}
.ai-status { display: flex; align-items: center; gap: 6px; margin-bottom: 4px; }
.ai-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--success); animation: pulse 2s infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

/* Main content */
.main { margin-left: var(--sidebar-w); flex: 1; display: flex; flex-direction: column; min-height: 100vh; }
.topbar {
  background: var(--bg2); border-bottom: 1px solid var(--border2);
  padding: 14px 28px; display: flex; align-items: center; justify-content: space-between;
  position: sticky; top: 0; z-index: 50;
}
.page-title { font-family: var(--font-head); font-size: 20px; color: var(--ivory); }
.page-sub { font-size: 11px; color: var(--ivory3); margin-top: 1px; }
.topbar-actions { display: flex; align-items: center; gap: 10px; }
.btn {
  padding: 8px 16px; border-radius: var(--radius); border: none; cursor: pointer;
  font-family: var(--font-body); font-size: 13px; font-weight: 500; transition: all var(--transition);
}
.btn-primary { background: var(--gold); color: var(--bg); }
.btn-primary:hover { background: var(--gold2); }
.btn-ghost { background: transparent; color: var(--ivory2); border: 1px solid var(--border); }
.btn-ghost:hover { background: var(--bg3); color: var(--ivory); }
.btn-danger { background: rgba(224,85,85,0.15); color: var(--danger); border: 1px solid rgba(224,85,85,0.3); }
.btn-sm { padding: 5px 12px; font-size: 12px; }

.content { padding: 28px; flex: 1; }

/* Page routing */
.page { display: none; }
.page.active { display: block; }

/* Stats grid */
.stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 28px; }
.stat-card {
  background: var(--bg2); border: 1px solid var(--border2); border-radius: var(--radius-lg);
  padding: 18px 20px; position: relative; overflow: hidden;
}
.stat-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, var(--gold), transparent);
}
.stat-label { font-size: 11px; color: var(--ivory3); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 8px; }
.stat-value { font-family: var(--font-mono); font-size: 28px; color: var(--ivory); font-weight: 500; }
.stat-meta { font-size: 11px; color: var(--ivory3); margin-top: 6px; }
.stat-up { color: var(--success); }
.stat-down { color: var(--danger); }

/* Grid 2-col */
.grid-2 { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; margin-bottom: 24px; }
.grid-2b { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }

/* Cards */
.card {
  background: var(--bg2); border: 1px solid var(--border2); border-radius: var(--radius-lg);
  padding: 20px;
}
.card-title {
  font-family: var(--font-head); font-size: 15px; color: var(--gold2);
  margin-bottom: 16px; display: flex; align-items: center; justify-content: space-between;
}
.card-title span { font-family: var(--font-body); font-size: 11px; color: var(--ivory3); font-weight: 400; }

/* Tables */
.table-wrap { border: 1px solid var(--border2); border-radius: var(--radius-lg); overflow: hidden; }
table { width: 100%; border-collapse: collapse; font-size: 13px; }
th {
  background: var(--bg3); color: var(--ivory3); font-weight: 500; text-align: left;
  padding: 11px 14px; font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em;
  border-bottom: 1px solid var(--border);
}
td { padding: 12px 14px; border-bottom: 1px solid var(--border2); color: var(--ivory2); vertical-align: middle; }
tr:last-child td { border-bottom: none; }
tr:hover td { background: rgba(255,255,255,0.02); }

/* Badges */
.badge { display: inline-block; font-size: 10px; padding: 3px 8px; border-radius: 99px; font-weight: 500; letter-spacing: 0.03em; }
.badge-elite { background: rgba(201,168,76,0.2); color: var(--gold2); border: 1px solid rgba(201,168,76,0.3); }
.badge-advanced { background: rgba(74,158,255,0.15); color: #7ab8ff; border: 1px solid rgba(74,158,255,0.25); }
.badge-intermediate { background: rgba(224,160,32,0.15); color: #f0b83a; border: 1px solid rgba(224,160,32,0.25); }
.badge-beginner { background: rgba(76,175,125,0.15); color: #6fd4a0; border: 1px solid rgba(76,175,125,0.25); }
.badge-paid { background: rgba(76,175,125,0.15); color: #6fd4a0; }
.badge-due { background: rgba(224,160,32,0.15); color: #f0b83a; }
.badge-overdue { background: rgba(224,85,85,0.15); color: #f08080; }

/* Avatar */
.avatar {
  width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center;
  justify-content: center; font-size: 11px; font-weight: 500; flex-shrink: 0;
}
.student-cell { display: flex; align-items: center; gap: 10px; }
.student-name { font-weight: 500; color: var(--ivory); font-size: 13px; }
.student-email { font-size: 11px; color: var(--ivory3); }

/* Controls */
.controls { display: flex; gap: 10px; margin-bottom: 16px; flex-wrap: wrap; align-items: center; }
.search-wrap { flex: 1; min-width: 200px; position: relative; }
.search-wrap input { width: 100%; padding-left: 34px; }
.search-icon { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: var(--ivory3); pointer-events: none; }
input, select, textarea {
  background: var(--bg3); border: 1px solid var(--border); border-radius: var(--radius);
  color: var(--ivory); font-family: var(--font-body); font-size: 13px;
  padding: 8px 12px; outline: none; transition: border var(--transition);
}
input:focus, select:focus, textarea:focus { border-color: var(--gold3); }
select option { background: var(--bg3); }
textarea { resize: vertical; }

/* Filters */
.filter-row { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px; }
.filter-chip {
  padding: 5px 12px; border-radius: 99px; font-size: 12px; cursor: pointer;
  border: 1px solid var(--border); color: var(--ivory3); background: transparent;
  font-family: var(--font-body); transition: all var(--transition);
}
.filter-chip:hover, .filter-chip.active { background: rgba(201,168,76,0.15); color: var(--gold2); border-color: rgba(201,168,76,0.3); }

/* AI Chat */
.chat-wrap { display: flex; flex-direction: column; height: 520px; }
.chat-messages {
  flex: 1; overflow-y: auto; padding: 16px; display: flex; flex-direction: column; gap: 14px;
  scrollbar-width: thin; scrollbar-color: var(--bg4) transparent;
}
.msg { display: flex; gap: 10px; animation: fadeIn 0.25s ease; }
@keyframes fadeIn { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:none} }
.msg.user { flex-direction: row-reverse; }
.msg-avatar {
  width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 500;
}
.msg-ai-av { background: rgba(201,168,76,0.2); color: var(--gold2); border: 1px solid rgba(201,168,76,0.3); font-size: 14px; }
.msg-user-av { background: rgba(74,158,255,0.2); color: #7ab8ff; }
.msg-bubble {
  max-width: 75%; padding: 10px 14px; border-radius: 12px; font-size: 13px; line-height: 1.6;
}
.msg.ai .msg-bubble { background: var(--bg3); color: var(--ivory2); border: 1px solid var(--border2); border-top-left-radius: 4px; }
.msg.user .msg-bubble { background: rgba(201,168,76,0.15); color: var(--ivory); border: 1px solid rgba(201,168,76,0.2); border-top-right-radius: 4px; }
.msg-time { font-size: 10px; color: var(--ivory3); margin-top: 4px; }
.chat-input-row { display: flex; gap: 10px; padding: 12px 16px; border-top: 1px solid var(--border2); }
.chat-input-row input { flex: 1; }
.typing-indicator { display: flex; gap: 4px; align-items: center; padding: 4px 0; }
.typing-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--ivory3); animation: typing 1.2s infinite; }
.typing-dot:nth-child(2){animation-delay:0.2s}
.typing-dot:nth-child(3){animation-delay:0.4s}
@keyframes typing { 0%,100%{opacity:0.3;transform:scale(0.8)} 50%{opacity:1;transform:scale(1)} }

/* PGN Analyzer */
.pgn-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.pgn-panel { display: flex; flex-direction: column; gap: 14px; }
.analysis-box {
  background: var(--bg3); border: 1px solid var(--border2); border-radius: var(--radius);
  padding: 16px; font-size: 13px; line-height: 1.7; color: var(--ivory2);
  min-height: 300px; max-height: 420px; overflow-y: auto;
}
.analysis-section { margin-bottom: 14px; }
.analysis-heading { font-family: var(--font-head); color: var(--gold2); font-size: 14px; margin-bottom: 6px; }
.analysis-list { list-style: none; }
.analysis-list li { padding: 4px 0; border-bottom: 1px solid var(--border2); }
.analysis-list li:last-child { border-bottom: none; }
.move-good { color: var(--success); }
.move-bad { color: var(--danger); }
.move-ok { color: var(--warning); }

/* Schedule */
.schedule-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 8px; margin-bottom: 20px; }
.day-col { }
.day-header { text-align: center; font-size: 11px; color: var(--ivory3); padding: 8px 4px; text-transform: uppercase; letter-spacing: 0.06em; }
.day-today .day-header { color: var(--gold2); }
.session-slot {
  background: var(--bg3); border: 1px solid var(--border2); border-radius: 8px;
  padding: 8px 10px; margin-bottom: 8px; font-size: 11px; cursor: pointer;
  border-left: 3px solid var(--gold3); transition: all var(--transition);
}
.session-slot:hover { background: var(--bg4); border-color: rgba(201,168,76,0.3); }
.session-slot.coach-fischer { border-left-color: #7ab8ff; }
.session-slot.coach-patel { border-left-color: var(--success); }
.session-slot.coach-nakamura { border-left-color: var(--gold); }
.session-name { font-weight: 500; color: var(--ivory); }
.session-time { color: var(--ivory3); margin-top: 2px; }

/* Billing */
.billing-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
.revenue-chart-wrap { height: 200px; margin-bottom: 20px; }

/* Modal */
.modal-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 200;
  display: flex; align-items: center; justify-content: center;
  backdrop-filter: blur(4px);
}
.modal-box {
  background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius-lg);
  padding: 28px; width: 460px; max-width: 95vw; max-height: 90vh; overflow-y: auto;
  animation: modalIn 0.22s ease;
}
@keyframes modalIn { from{opacity:0;transform:scale(0.95)} to{opacity:1;transform:none} }
.modal-title { font-family: var(--font-head); font-size: 18px; color: var(--gold2); margin-bottom: 22px; }
.form-row { margin-bottom: 14px; }
.form-label { font-size: 11px; color: var(--ivory3); margin-bottom: 5px; display: block; text-transform: uppercase; letter-spacing: 0.05em; }
.form-row input, .form-row select, .form-row textarea { width: 100%; }
.form-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.modal-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 22px; }

/* Notification toast */
.toast {
  position: fixed; bottom: 24px; right: 24px; background: var(--bg2);
  border: 1px solid var(--gold3); border-radius: var(--radius); padding: 12px 18px;
  font-size: 13px; color: var(--ivory); z-index: 300; display: none;
  animation: toastIn 0.25s ease;
}
@keyframes toastIn { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:none} }

/* Quick insights */
.insight-item {
  display: flex; align-items: flex-start; gap: 10px; padding: 10px 0;
  border-bottom: 1px solid var(--border2);
}
.insight-item:last-child { border-bottom: none; }
.insight-icon { width: 28px; height: 28px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 14px; flex-shrink: 0; }
.insight-text { font-size: 12px; color: var(--ivory2); line-height: 1.5; }
.insight-text strong { color: var(--ivory); }

/* ELO bar */
.elo-bar { display: flex; align-items: center; gap: 8px; }
.elo-track { flex: 1; height: 4px; background: var(--bg4); border-radius: 99px; overflow: hidden; }
.elo-fill { height: 100%; background: var(--gold); border-radius: 99px; }

/* Activity feed */
.activity-item { display: flex; gap: 10px; padding: 10px 0; border-bottom: 1px solid var(--border2); font-size: 12px; }
.activity-item:last-child { border-bottom: none; }
.activity-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; margin-top: 4px; }
.activity-text { color: var(--ivory2); line-height: 1.5; }
.activity-time { color: var(--ivory3); font-size: 11px; margin-top: 2px; }

/* Scrollbar */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--bg4); border-radius: 99px; }

/* Responsive */
@media(max-width:900px) {
  :root { --sidebar-w: 0px; }
  .sidebar { transform: translateX(-220px); width: 220px; }
  .main { margin-left: 0; }
  .stats-grid { grid-template-columns: 1fr 1fr; }
  .grid-2, .grid-2b, .pgn-layout { grid-template-columns: 1fr; }
}
</style>
</head>
