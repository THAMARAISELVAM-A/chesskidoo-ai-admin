// SCHEDULE
// ──────────────────────────────────────────
const DAYS = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
const DATES = ['Mar 24','Mar 25','Mar 26','Mar 27','Mar 28','Mar 29','Mar 30'];

function renderSchedule(){
  const grid = document.getElementById('schedule-grid');
  grid.innerHTML = DAYS.map((d,i)=>{
    const daySessions = sessions.filter(s=>s.day===d);
    const isToday = d==='Tue';
    return `<div class="day-col ${isToday?'day-today':''}">
      <div class="day-header">${d}<br><span style="font-size:10px">${DATES[i]}</span></div>
      ${daySessions.map(s=>{
        const cls = s.coach.includes('Fischer')?'coach-fischer':s.coach.includes('Patel')?'coach-patel':'coach-nakamura';
        return `<div class="session-slot ${cls}">
          <div class="session-name">${s.student.split(' ')[0]}</div>
          <div class="session-time">${s.time}</div>
        </div>`;
      }).join('')}
    </div>`;
  }).join('');

  const tbody = document.getElementById('sessions-tbody');
  tbody.innerHTML = sessions.map(s=>{
    const statusColor = s.status==='Completed'?'badge-paid':s.status==='Today'?'badge-intermediate':'';
    return `<tr>
      <td style="color:var(--ivory)">${s.student}</td>
      <td style="color:var(--ivory3);font-size:12px">${s.coach}</td>
      <td style="font-size:12px">${s.date}</td>
      <td style="font-family:var(--font-mono);font-size:12px">${s.time}</td>
      <td style="color:var(--ivory3);font-size:12px">${s.focus}</td>
      <td><span class="badge ${statusColor}">${s.status}</span></td>
    </tr>`;
  }).join('');
}

