function initials(name){ return name.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase(); }

function renderStudents() {
  const q = (document.getElementById('s-search').value||'').toLowerCase();
  const fl = document.getElementById('s-level').value;
  const fp = document.getElementById('s-pay').value;
  const fc = document.getElementById('s-coach').value;
  const list = students.filter(s =>
    (!q || s.name.toLowerCase().includes(q) || s.email.toLowerCase().includes(q)) &&
    (!fl || s.level===fl) && (!fp || s.payment===fp) && (!fc || s.coach===fc)
  );
  const tbody = document.getElementById('students-tbody');
  if(!list.length){ tbody.innerHTML=`<tr><td colspan="7" style="text-align:center;color:var(--ivory3);padding:32px">No students match the filter</td></tr>`; return; }
  tbody.innerHTML = list.map(s=>`
    <tr>
      <td><div class="student-cell">
        <div class="avatar" style="${avatarStyle(s.name)}">${initials(s.name)}</div>
        <div><div class="student-name">${s.name}</div><div class="student-email">${s.email}</div></div>
      </div></td>
      <td><span class="badge badge-${s.level.toLowerCase()}">${s.level}</span></td>
      <td><span style="font-family:var(--font-mono)">${s.elo}</span></td>
      <td style="color:var(--ivory3);font-size:12px">${s.coach}</td>
      <td style="font-family:var(--font-mono);font-size:12px">${s.sessions}</td>
      <td><span class="badge badge-${s.payment.toLowerCase()}">${s.payment}</span></td>
      <td>
        <button class="btn btn-ghost btn-sm" onclick="openEditStudent(${s.id})">Edit</button>
        <button class="btn btn-ghost btn-sm" style="margin-left:4px" onclick="viewStudentAI(${s.id})">AI Report</button>
      </td>
    </tr>`).join('');
  updateOverdueBadge();
  document.getElementById('ctx-count').textContent = students.length;
}

function updateOverdueBadge(){
  const n = students.filter(s=>s.payment==='Overdue').length;
  const el = document.getElementById('overdue-badge');
  if(n>0){ el.textContent=n; el.style.display=''; }
  else el.style.display='none';
}

function openAddStudent(){
  editId=null;
  document.getElementById('student-modal-title').textContent='Add New Student';
  ['m-name','m-email','m-notes'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('m-elo').value='';
  document.getElementById('m-fee').value='';
  document.getElementById('m-level').value='Beginner';
  document.getElementById('m-pay').value='Paid';
  document.getElementById('student-modal').style.display='flex';
}

function openEditStudent(id){
  const s = students.find(x=>x.id===id);
  if(!s) return;
  editId=id;
  document.getElementById('student-modal-title').textContent='Edit Student';
  document.getElementById('m-name').value=s.name;
  document.getElementById('m-email').value=s.email;
  document.getElementById('m-level').value=s.level;
  document.getElementById('m-elo').value=s.elo;
  document.getElementById('m-coach').value=s.coach;
  document.getElementById('m-fee').value=s.fee||8000;
  document.getElementById('m-pay').value=s.payment;
  document.getElementById('m-notes').value=s.notes||'';
  document.getElementById('student-modal').style.display='flex';
}

function saveStudent(){
  const name = document.getElementById('m-name').value.trim();
  if(!name){ showToast('Please enter a student name'); return; }
  const data = {
    name, email:document.getElementById('m-email').value.trim(),
    level:document.getElementById('m-level').value,
    elo:parseInt(document.getElementById('m-elo').value)||800,
    coach:document.getElementById('m-coach').value,
    fee:parseInt(document.getElementById('m-fee').value)||8000,
    payment:document.getElementById('m-pay').value,
    notes:document.getElementById('m-notes').value.trim(),
  };
  if(editId){ Object.assign(students.find(x=>x.id===editId), data); }
  else { students.push({id:nextId++, sessions:0, ...data}); }
  closeModal('student-modal');
  renderStudents();
  updateStats();
  showToast(editId ? 'Student updated' : 'Student added successfully');
}

function viewStudentAI(id){
  const s = students.find(x=>x.id===id);
  nav('assistant');
  setTimeout(()=>quickPrompt(`Give me a detailed progress report for ${s.name} — ELO ${s.elo}, level: ${s.level}, ${s.sessions} sessions completed, coach: ${s.coach}. Include strengths, weaknesses, and next 4 weeks recommendations.`), 200);
}

